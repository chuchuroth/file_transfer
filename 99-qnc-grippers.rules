# udev rules for QNC gripper RS485 adapters
# Install: sudo cp scripts/99-qnc-grippers.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules && sudo udevadm trigger
#
# Creates stable symlinks regardless of which USB port each adapter is in:
#   /dev/gripper_ag160  →  FTDI FT232R serial BG011K9H  (DH AG-160)
#   /dev/gripper_cgc80  →  FTDI FT232R serial B001PRSH  (DH CGC-80)
#   /dev/gripper_dh56   →  FTDI FT232R serial BG00SMUT  (DH-5-6)

SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", \
    ATTRS{serial}=="BG011K9H", SYMLINK+="gripper_ag160"

SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", \
    ATTRS{serial}=="B001PRSH", SYMLINK+="gripper_cgc80"

SUBSYSTEM=="tty", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", \
    ATTRS{serial}=="BG00SMUT", SYMLINK+="gripper_dh56"
